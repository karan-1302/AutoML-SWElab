# backend/.env
# Copy this file to .env and fill in real values before deploying to production.

# JWT Secret — change this to a long random string in production
JWT_SECRET_KEY=cs331-change-this-to-a-random-secret-in-production

# App environment
APP_ENV=development

# Database URL (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./automl.db

# (Optional) Supabase connection string when replacing SQLite
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# (Optional) DagsHub MLflow tracking URI
# MLFLOW_TRACKING_URI=https://dagshub.com/username/repo.mlflow
