# Lab 5: Environment Variables Template
# Copy this to .env and fill in your values
# NEVER commit .env to git — add it to .gitignore

# ── Application ───────────────────────────────────────────────
APP_NAME=RealEstateAutoML
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# ── API Configuration ─────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Security ──────────────────────────────────────────────────
# Generate a random 32-char string for production
SECRET_KEY=lab5-change-this-in-production-use-random-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Database (Supabase PostgreSQL) ────────────────────────────
# Format: postgresql://user:password@host:5432/database
# Get this from your Supabase project settings
DATABASE_URL=postgresql://user:password@host:5432/database

# ── MLflow / DagsHub (Model Registry) ─────────────────────────
# Get these from your DagsHub repository settings
DAGSHUB_USER_TOKEN=your-dagshub-token-here
MLFLOW_TRACKING_URI=https://dagshub.com/your-username/your-repo.mlflow

# ── CORS (Cross-Origin Resource Sharing) ──────────────────────
# Comma-separated list of allowed origins
# Local dev: http://localhost:3000
# Production: https://your-vercel-app.vercel.app
CORS_ORIGINS=http://localhost:3000,https://real-estate-automl.vercel.app

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
